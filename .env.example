# MongoDB Configuration
# Atlas connection string format:
MONGODB_URI=mongodb+srv://prism_admin:PASSWORD@cluster0.pbf5oy8.mongodb.net/?appName=Cluster0
MONGODB_DB=prism

# Local MongoDB (alternative):
# MONGODB_URI=mongodb://localhost:27017

# AWS Configuration (for aws-ec2 collector)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Azure Configuration (for azure-vms collector)
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_TENANT_ID=your_tenant_id           # Optional: uses DefaultAzureCredential if omitted
AZURE_CLIENT_ID=your_client_id           # Optional: for Service Principal auth
AZURE_CLIENT_SECRET=your_client_secret   # Optional: for Service Principal auth

# CrowdStrike Configuration (for crowdstrike collector)
CROWDSTRIKE_CLIENT_ID=your_client_id
CROWDSTRIKE_CLIENT_SECRET=your_client_secret
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com  # Optional: defaults to US cloud

# Jira Configuration (for jira-assets collector)
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_api_token
JIRA_PROJECT_KEY=ASSET  # Optional: defaults to ASSET

# Windmill Configuration (optional)
WINDMILL_URL=https://your-windmill-instance.com
WINDMILL_TOKEN=your_windmill_token
